# ConfigFlow Iran Worker — config.env
# Copy to config.env and fill in your values.

# URL of the Bot API server (running on the foreign/outside server)
BOT_API_URL=http://YOUR_FOREIGN_SERVER_IP:8080

# Shared secret between the bot and this worker.
# Must match the WORKER_API_KEY set in the bot's admin panel (⚙️ Worker API Settings).
WORKER_API_KEY=your-api-key-here-min-16-chars

# 3x-ui panel connection details (usually 127.0.0.1 when on the same machine)
PANEL_IP=127.0.0.1
PANEL_PORT=2053
PANEL_PATCH=
PANEL_USERNAME=admin
PANEL_PASSWORD=your-panel-password

# The 3x-ui inbound ID to create clients in (find it in the panel UI)
INBOUND_ID=1

# VPN protocol: vless | vmess | trojan
PROTOCOL=vless

# How often (in seconds) to poll the Bot API for new jobs
POLL_INTERVAL=10
